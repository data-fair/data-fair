{
  "name": "@data-fair/data-fair-benchmark",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "benchmark": "node --experimental-strip-types --disable-warning=ExperimentalWarning src/index.ts",
    "benchmark-csv": "node --expose-gc --experimental-strip-types --disable-warning=ExperimentalWarning src/csv-serialize/bench.ts",
    "benchmark-streaming": "node --expose-gc --max-semi-space-size=128 --experimental-strip-types --disable-warning=ExperimentalWarning src/streaming-parse/bench.ts",
    "benchmark-streaming-pipeline": "node --expose-gc --experimental-strip-types --disable-warning=ExperimentalWarning src/streaming-parse/streaming/bench.ts"
  },
  "dependencies": {
    "@fast-csv/format": "^4.3.5",
    "autocannon": "^8.0.0",
    "csv-stringify": "^6.5.2"
  },
  "devDependencies": {
    "@streamparser/json": "^0.0.22",
    "@types/autocannon": "^7.12.0",
    "simdjson": "^0.9.2"
  }
}
