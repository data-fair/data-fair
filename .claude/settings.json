{
  "permissions": {
    "allow": [
      "Bash",
      "Edit",
      "Write",
      "NotebookEdit",
      "WebFetch",
      "WebSearch",
      "mcp__playwright-test__*",
      "mcp__vuetify__*"
    ],
    "deny": []
